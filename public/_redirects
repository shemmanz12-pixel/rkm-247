# Public redirects for Netlify.
# NOTE: the greedy redirect from
#   /local-plumber/:area/ -> /local-plumber/in-:area/
# was removed because it re-matched already-canonical paths and caused
# repeated "in-in-..." redirect chains. A safe regex-based redirect
# (negative lookahead) is defined in `netlify.toml` and will be used in
# Netlify's config to transform legacy /local-plumber/<area>/ URLs.

# Service town redirects (map legacy town-friendly routes to canonical 'in-' pages)
/emergency-plumber/:area/    /emergency-plumber/in-:area/    301!
/drain-unblocking/:area/     /drain-unblocking/in-:area/     301!
/heating-engineer/:area/     /heating-engineer/in-:area/     301!
/leak-detection/:area/      /leak-detection/in-:area/      301!

# Legacy plumber-in pages map to the canonical local-plumber paths
# (these are static legacy filenames -> canonical)
/plumber-in-:area/           /local-plumber/in-:area/       301!
/plumber-in-:area.html      /local-plumber/in-:area/       301!

# Serve sitemap correctly from root
/_sitemap.xml  /sitemap.xml  200

# Redirect any legacy .html requests to trailing-slash canonical (force single URL)
/*.html  /:splat/  301!